# Supabase URL — put your regular Supabase project URL here
# (e.g. https://xxxxx.supabase.co). The code auto-detects OptiDev gateway URLs.
VITE_SUPABASE_GATEWAY_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings > API > Project API keys > anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Google Custom Search Engine ID (for YouTube search feature) — optional
VITE_GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id
